---
import Layout from '../../layouts/Layout.astro';
import Site from '../../components/App.jsx';
import { I18N } from '../../lib/i18n.jsx';
import { projectSeo } from '../../lib/seo.js';

export function getStaticPaths() {
  return I18N.en.projects.map((p) => ({
    params: { slug: p.slug || p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { slug } = Astro.params;
const seo = projectSeo('en', project, slug);
---

<Layout
  title={seo.title}
  description={seo.description}
  image={seo.image}
  type={seo.type}
  lang={seo.lang}
  path={seo.path}
  jsonLd={seo.jsonLd}
>
  <div id="root">
    <Site client:idle initialRoute="project" initialParam={slug} initialLang="en" />
  </div>
</Layout>
