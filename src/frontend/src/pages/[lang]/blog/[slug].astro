---
import { render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogChrome from '../../../components/BlogChrome.jsx';
import { blogPostSeo, localeUrl, LOCALES, DEFAULT_LOCALE } from '../../../lib/seo.js';
import { postsForLang, slugOf, toCard } from '../../../lib/blog.js';

export async function getStaticPaths() {
  const out = [];
  for (const lang of LOCALES.filter((l) => l !== DEFAULT_LOCALE)) {
    const posts = await postsForLang(lang);
    for (const entry of posts) {
      out.push({ params: { lang, slug: slugOf(entry) }, props: { entry } });
    }
  }
  return out;
}

const { lang, slug } = Astro.params;
const { entry } = Astro.props;
const post = toCard(entry);
const seo = blogPostSeo(lang, entry.data, slug);
const langPaths = Object.fromEntries(LOCALES.map((l) => [l, localeUrl(l, `blog/${slug}`)]));
const { Content } = await render(entry);
---

<Layout
  title={seo.title}
  description={seo.description}
  image={seo.image}
  type={seo.type}
  lang={seo.lang}
  path={seo.path}
  jsonLd={seo.jsonLd}
>
  <BlogChrome client:load post={post} lang={lang} langPaths={langPaths}>
    <Content />
  </BlogChrome>
</Layout>
