---
import Layout from '../layouts/Layout.astro';
import Site from '../components/App.jsx';
import { I18N } from '../lib/i18n.jsx';

const C = I18N.en;
const site = (Astro.site ?? new URL('https://nomaddigital.dev')).href.replace(/\/$/, '');

const title = 'About — Michiel Van Herreweghe';
const description = C.ui.aboutP1;

// ProfilePage wraps a Person describing the page's main subject — gives Google
// + LLM crawlers an explicit "this page is the author's profile" signal and
// links to the Person `@id` declared on the homepage so the graph stays
// connected. Includes `worksFor` so the experience timeline is structured
// data, not just rendered HTML.
const profileLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': site + '/about/#profile',
  url: site + '/about/',
  name: title,
  description,
  inLanguage: 'en',
  mainEntity: {
    '@type': 'Person',
    '@id': site + '/#person',
    name: C.name,
    jobTitle: C.role,
    description,
    url: site + '/',
    address: { '@type': 'PostalAddress', addressCountry: 'BE', addressRegion: C.location },
    knowsAbout: C.stack,
    sameAs: C.socials.map((s) => s.href),
    worksFor: C.experience.map((e) => ({
      '@type': 'OrganizationRole',
      roleName: e.role,
      startDate: (e.period.match(/\d{4}/) || [undefined])[0],
      member: { '@type': 'Organization', name: e.org },
    })),
    alumniOf: C.education.map((e) => ({ '@type': 'EducationalOrganization', name: e.org })),
    hasCredential: C.certifications.map((c) => ({
      '@type': 'EducationalOccupationalCredential',
      name: c.title,
      credentialCategory: 'Certification',
    })),
  },
};

// BreadcrumbList for /about — gives Google rich result eligibility and a
// breadcrumb trail in the SERP snippet.
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: site + '/about/' },
  ],
};
---

<Layout title={title} description={description} jsonLd={[profileLd, breadcrumbLd]}>
  <div id="root">
    <Site client:load initialRoute="about" />
  </div>
</Layout>
