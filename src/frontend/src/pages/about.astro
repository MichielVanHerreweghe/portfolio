---
import Layout from '../layouts/Layout.astro';
import Site from '../components/App.jsx';
import { I18N } from '../lib/i18n.jsx';

const C = I18N.en;

const title = 'About — Michiel Van Herreweghe';
const description = C.ui.aboutP1;
---

