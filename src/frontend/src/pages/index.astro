---
import Layout from '../layouts/Layout.astro';
import Site from '../components/App.jsx';
import { I18N } from '../lib/i18n.jsx';

const C = I18N.en;
const site = (Astro.site ?? new URL('https://nomaddigital.dev')).href.replace(/\/$/, '');

const title = 'Michiel Van Herreweghe — DevOps & Software Engineer';
const description = C.ui.heroIntro;

// schema.org Person — helps Google build a knowledge panel and understand who
// this site is about.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: C.name,
  url: site + '/',
  jobTitle: C.role,
  description,
  address: { '@type': 'PostalAddress', addressCountry: C.location },
  knowsAbout: C.stack,
  sameAs: C.socials.map((s) => s.href),
};
---

<Layout title={title} description={description} jsonLd={personLd}>
  <div id="root">
    <Site client:load initialRoute="home" />
  </div>
</Layout>
