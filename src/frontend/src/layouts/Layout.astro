---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Path to a social-share image in /public (1200×630 recommended). */
  image?: string;
  /** og:type — "website" for pages, "article" for project case-studies. */
  type?: string;
  /** Discourage indexing of this page (e.g. utility pages). */
  noindex?: boolean;
  /** One or more schema.org JSON-LD objects to embed. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Michiel Van Herreweghe — DevOps & Software Engineer',
  description = 'DevOps & Software Engineer building resilient pipelines, clean infrastructure, and software that ships.',
  image = '/og.png',
  type = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

// Astro.site is set in astro.config.mjs. Fall back gracefully if it's missing.
const site = Astro.site ?? new URL('https://nomaddigital.dev');
const canonical = new URL(Astro.url.pathname, site).href;
const imageUrl = new URL(image, site).href;
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large" />}
    <meta name="author" content="Michiel Van Herreweghe" />
    <meta name="theme-color" content="#0B0B0C" />

    {/* hreflang — all three language variants of every page live at the
        same URL (i18n is currently a client-side localStorage swap), so we
        advertise the canonical URL for each `hreflang` plus `x-default`.
        This is the minimum signal that the EN URL is intended to serve all
        three audiences until path-prefix i18n is introduced. */}
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="nl" href={canonical} />
    <link rel="alternate" hreflang="fr" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Michiel Van Herreweghe" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="nl_BE" />
    <meta property="og:locale:alternate" content="fr_BE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    {/* Apply persisted theme + language before paint to avoid a flash. */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('mvh-theme');
          document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark');
          var l = localStorage.getItem('mvh-lang');
          if (l === 'en' || l === 'nl' || l === 'fr') document.documentElement.lang = l;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
    {/* User-fillable <image-slot> custom element (drag-and-drop image placeholders). */}
    <script is:inline src="/image-slot.js"></script>
  </body>
</html>
