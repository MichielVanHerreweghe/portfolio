---
import '../styles/global.css';
import { alternatesFor, OG_LOCALE, LOCALES } from '../lib/seo.js';

interface Props {
  title?: string;
  description?: string;
  /** Path to a social-share image in /public (1200×630 recommended). */
  image?: string;
  /** og:type — "website" for pages, "article" for project case-studies. */
  type?: string;
  /** Discourage indexing of this page (e.g. utility pages). */
  noindex?: boolean;
  /** One or more schema.org JSON-LD objects to embed. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Page locale — drives <html lang>, og:locale and the active hreflang. */
  lang?: string;
  /** Logical path without locale prefix ('', 'about', 'portfolio',
   *  'projects/<slug>') — used to build the hreflang alternates. */
  path?: string;
}

const {
  title = 'Michiel Van Herreweghe — DevOps & Software Engineer',
  description = 'DevOps & Software Engineer building resilient pipelines, clean infrastructure, and software that ships.',
  image = '/og.png',
  type = 'website',
  noindex = false,
  jsonLd,
  lang = 'en',
  path = '',
} = Astro.props;

// Astro.site is set in astro.config.mjs. Fall back gracefully if it's missing.
const site = Astro.site ?? new URL('https://nomaddigital.dev');
const canonical = new URL(Astro.url.pathname, site).href;
const imageUrl = new URL(image, site).href;
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// hreflang alternates — each language at its own real URL (+ x-default).
const alternates = alternatesFor(path);
const ogLocale = OG_LOCALE[lang] ?? 'en_US';
const ogLocaleAlternates = LOCALES.filter((l) => l !== lang).map((l) => OG_LOCALE[l]);
---

<!DOCTYPE html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large" />}
    <meta name="author" content="Michiel Van Herreweghe" />
    <meta name="theme-color" content="#0B0B0C" />

    {/* hreflang — each locale lives at its own URL (English at the root,
        Dutch/French path-prefixed), so we advertise the real per-language URL
        plus x-default → the English (default) URL. */}
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Michiel Van Herreweghe" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />

    {/* Fonts — self-hosted (see scripts/fetch-fonts.mjs). No third-party origin:
        visitor IPs never reach Google (GDPR) and the CSP needs no font CDN
        allowance. fonts.css carries @font-face with `display: swap` (text shows
        immediately in the fallback) and per-subset unicode-range (latin-ext only
        downloads when a glyph needs it). The body font is preloaded so the LCP
        heading swaps without a flash. Font preloads are CORS-fetched, hence
        crossorigin even though same-origin. */}
    <link rel="preload" href="/fonts/space-grotesk-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    {/* Apply persisted theme before paint (avoids a flash). Language is NOT
        touched here — the URL (path-prefix i18n) is the source of truth, and
        <html lang> is set server-side per locale, so a stale localStorage value
        must not override it. */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('mvh-theme');
          document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
    {/* User-fillable <image-slot> custom element (drag-and-drop image placeholders). */}
    <script is:inline src="/image-slot.js"></script>
  </body>
</html>
